  "item": [
    {
      "name": "auth",
      "item": [
        {
          "name": "TC-AUTH-001 - Login User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", () => pm.response.to.have.status(200));\r",
                  "pm.test(\"Response has access_token\", () => {\r",
                  "    const jsonData = pm.response.json();\r",
                  "    pm.expect(jsonData).to.have.property(\"access_token\");\r",
                  "    pm.environment.set(\"token\", jsonData.access_token);\r",
                  "});\r",
                  "pm.test(\"Token type is bearer\", () => {\r",
                  "    pm.expect(pm.response.json().token_type).to.eql(\"bearer\");\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded",
                "type": "text"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "username",
                  "value": "admin",
                  "type": "text",
                  "uuid": "9ab487f8-9db8-4550-a536-fdd5b8dec6ad"
                },
                {
                  "key": "password",
                  "value": "admin123",
                  "type": "text",
                  "uuid": "4a71dd4a-05d5-4062-99f3-1d63124047cb"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/token",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "token"
              ]
            }
          },
          "response": []
        }
      ]
    },
